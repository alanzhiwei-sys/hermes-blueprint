# Hermes Blueprint — Base Config Template
# 
# This is a STARTING POINT for customer Hermes configuration.
# All values marked with YOUR_* must be filled in by the customer.
# DO NOT use this file directly — it's a template.
#
# Generated by Hermes Blueprint

# ── Model Provider ───────────────────────────────────────────────────
# Primary provider: openrouter, deepseek, anthropic, custom, etc.
model:
  provider: openrouter                                   # YOUR_PROVIDER
  model: anthropic/claude-sonnet-4                      # YOUR_MODEL
  fallback_provider: ''                                  # YOUR_FALLBACK_PROVIDER
  fallback_model: ''                                     # YOUR_FALLBACK_MODEL

# ── Memory ───────────────────────────────────────────────────────────
memory:
  memory_enabled: true
  user_profile_enabled: true
  write_approval: false
  memory_char_limit: 2200
  user_char_limit: 1375
  provider: mnemosyne
  flush_min_turns: 6
  nudge_interval: 10
  mnemosyne:
    profile_isolation: true
    ignore_patterns:
      - '^\[?1 image\]? '
      - 'Classify this renovation photo'
      - 'sorting renovation project media into folders'
      - 'Return ONLY a JSON object'
      - 'JSON-only: Score this benchmark output'
      - '^Reply (exactly|with exactly):? (OK|ok)$'
      - '^respond with just the word OK$'
      - '^ASYNC DELEGATION BATCH COMPLETE'
      - 'background fan-out of [0-9]+ subagent'
      - '^Progress Report$'
      - '^Progress — [0-9]+ of [0-9]+ batches complete$'
      - 'skill buildout complete'

# ── Delegation ───────────────────────────────────────────────────────
delegation:
  max_concurrent_children: 3
  max_spawn_depth: 1
  child_timeout_seconds: 600

# ── Context ──────────────────────────────────────────────────────────
context:
  engine: lcm

# ── Terminal ─────────────────────────────────────────────────────────
terminal:
  backend: local
  background_notifications: true

# ── Gateway (Telegram) ───────────────────────────────────────────────
# Uncomment and configure if using Telegram
# telegram:
#   bot_token: YOUR_TELEGRAM_BOT_TOKEN
#   allowed_users: []
#   home_channel: YOUR_HOME_CHANNEL_ID

# ── Home Assistant (optional) ────────────────────────────────────────
# hass:
#   url: YOUR_HASS_URL
#   token: YOUR_HASS_TOKEN

# ── Skills ───────────────────────────────────────────────────────────
skills:
  external_dirs: []
  template_vars: true

# ── Goals ────────────────────────────────────────────────────────────
goals:
  max_turns: 20
